# Akamai EdgeGrid credentials — get from Akamai Control Center > Identity & Access Management
AKAMAI_HOST=akab-xxxx.luna.akamaiapis.net
AKAMAI_CLIENT_TOKEN=akab-xxxx
AKAMAI_CLIENT_SECRET=xxxx
AKAMAI_ACCESS_TOKEN=akab-xxxx

# Transport: stdio (default), http, sse
AKAMAI_TRANSPORT=stdio

# HTTP transport port (only used when AKAMAI_TRANSPORT=http)
AKAMAI_HTTP_PORT=8080

# Logging: json (default) or text
AKAMAI_LOG_FORMAT=json
AKAMAI_LOG_LEVEL=INFO

# Property index refresh interval in seconds (default: 300)
AKAMAI_INDEX_REFRESH_INTERVAL=300
